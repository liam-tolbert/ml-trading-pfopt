  {
   "cell_type": "code",
   "id": "ffe107e02e4c1b3d",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-05-22T02:03:14.193209Z",
     "iopub.status.busy": "2026-05-22T02:03:14.193209Z",
     "iopub.status.idle": "2026-05-22T02:03:14.204019Z",
     "shell.execute_reply": "2026-05-22T02:03:14.203263Z"
    },
    "ExecuteTime": {
     "end_time": "2026-05-24T02:32:28.610400Z",
     "start_time": "2026-05-24T02:32:28.554193900Z"
    }
   },
   "source": [
    "import time\n",
    "\n",
    "def _last_friday():\n",
    "    today = pd.Timestamp.now().normalize()\n",
    "    days_since_friday = (today.weekday() - 4) % 7\n",
    "    return today - pd.Timedelta(days=days_since_friday)\n",
    "\n",
    "def download_and_fix_yfinance_data(stocks, csv_filename, force_refresh=False, sleep_per_call=0.15):\n",
    "    \"\"\"\n",
    "    Refresh weekly OHLCV for `stocks` into a single combined CSV.\n",
    "\n",
    "    Per-ticker incremental caching:\n",
    "      - Tickers already in the CSV with data through the current week are reused as-is.\n",
    "      - Tickers missing or with stale data get re-downloaded.\n",
    "      - Tickers no longer in `stocks` are dropped.\n",
    "    Pass force_refresh=True to ignore the cache.\n",
    "\n",
    "    sleep_per_call adds a small delay between yfinance hits to stay under rate limits.\n",
    "    \"\"\"\n",
    "    csv_path = csv_filename if csv_filename.endswith('.csv') else csv_filename + '.csv'\n",
    "    threshold = _last_friday() - pd.Timedelta(days=1)\n",
    "\n",
    "    # 1) Inspect cache, decide which tickers can be skipped\n",
    "    cached = None\n",
    "    fresh_tickers = set()\n",
    "    if not force_refresh and os.path.exists(csv_path):\n",
    "        cached = pd.read_csv(csv_path, parse_dates=['Date']).set_index('Date')\n",
    "        for col in cached.columns:\n",
    "            if not col.startswith('Close_'):\n",
    "                continue\n",
    "            ticker = col.split('_', 1)[1]\n",
    "            series = cached[col].dropna()\n",
    "            if not series.empty and series.index.max() >= threshold:\n",
    "                fresh_tickers.add(ticker)\n",
    "\n",
    "    requested = set(stocks)\n",
    "    to_download = [t for t in stocks if t not in fresh_tickers]\n",
    "    print(f\"{len(stocks) - len(to_download)} ticker(s) already cached + fresh; \"\n",
    "          f\"{len(to_download)} to fetch from yfinance\")\n",
    "\n",
    "    # 2) Download only the missing/stale tickers, with inter-call delay\n",
    "    new_frames = {}\n",
    "    failed = []\n",
    "    for i, t in enumerate(to_download, 1):\n",
    "        try:\n",
    "            df = yf.download(t, interval='1d', start='2015-01-01',\n",
    "                             auto_adjust=True, progress=False)\n",
    "        except Exception as e:\n",
    "            print(f\"  [{i}/{len(to_download)}] {t}: failed ({e!r}) — skipping\")\n",
    "            failed.append(t)\n",
    "            continue\n",
    "        if df.empty:\n",
    "            print(f\"  [{i}/{len(to_download)}] {t}: empty response — skipping\")\n",
    "            failed.append(t)\n",
    "            continue\n",
    "        df = df.resample('W-FRI').agg({\n",
    "            ('Open', t):   'first',\n",
    "            ('High', t):   'max',\n",
    "            ('Low', t):    'min',\n",
    "            ('Close', t):  'last',\n",
    "            ('Volume', t): 'sum',\n",
    "        })\n",
    "        new_frames[t] = df\n",
    "        if sleep_per_call:\n",
    "            time.sleep(sleep_per_call)\n",
    "        if i % 25 == 0:\n",
    "            print(f\"  ...{i}/{len(to_download)} downloaded\")\n",
    "\n",
    "    # 3) Assemble: cached subset (only requested tickers) + newly downloaded\n",
    "    parts = []\n",
    "    if cached is not None:\n",
    "        keep_cols = [c for c in cached.columns\n",
    "                     if c.split('_', 1)[-1] in (fresh_tickers & requested)]\n",
    "        if keep_cols:\n",
    "            parts.append(cached[keep_cols])\n",
    "    if new_frames:\n",
    "        new_combined = pd.concat(new_frames.values(), axis=1, join='outer')\n",
    "        new_combined.columns = ['_'.join(col) if isinstance(col, tuple) else col\n",
    "                                for col in new_combined.columns]\n",
    "        parts.append(new_combined)\n",
    "    if not parts:\n",
    "        raise RuntimeError(\"No data: nothing cached and nothing downloaded successfully\")\n",
    "\n",
    "    combined = pd.concat(parts, axis=1, join='outer').sort_index().ffill()\n",
    "\n",
    "    # Drop tickers with too-few observations\n",
    "    non_nan_counts = combined.count()\n",
    "    combined = combined.drop(columns=non_nan_counts[non_nan_counts < 20].index)\n",
    "    combined.index.name = 'Date'\n",
    "    combined.to_csv(csv_path)\n",
    "\n",
    "    n_tickers = sum(1 for c in combined.columns if c.startswith('Close_'))\n",
    "    print(f\"Saved {csv_path}: {n_tickers} ticker(s) total\" +\n",
    "          (f\"; {len(failed)} failed: {failed}\" if failed else \"\"))\n",
    "    return combined\n"
   ],
   "outputs": [],
   "execution_count": 9
  },
  {
   "cell_type": "code",
   "id": "6a3daf01-2ff0-457f-b113-57cc8da117c8",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-05-22T02:03:14.205525Z",
