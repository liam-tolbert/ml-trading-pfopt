    "    \"RGTI\", \"S\", \"SAIC\", \"SCHD\", \"SEZL\", \"SKYW\", \"SMCI\", \"SMTC\", \"SNOW\", \"SOXL\",\n",
    "    \"SYM\", \"TEAM\", \"TEM\", \"TOST\", \"TSM\", \"U\", \"UBER\", \"UPST\", \"URA\", \"VIST\",\n",
