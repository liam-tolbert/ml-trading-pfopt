   "source": [
    "# Diagnostic: class distribution across splits + per-ticker label concentration\n",
    "train, val, test = overall_sets\n",
    "for name, split in [(\"train\", train), (\"val\", val), (\"test\", test)]:\n",
    "    dist = split[\"Signal\"].value_counts(normalize=True).sort_index()\n",
    "    n = len(split)\n",
    "    print(f\"{name:5s} (n={n:6d}):  \"\n",
    "          f\"Sell={dist.get(0, 0):.2%}  Buy={dist.get(1, 0):.2%}  Hold={dist.get(2, 0):.2%}\")\n",
    "print()\n",
    "# Per-stock concentration check (Hold==2 only present in 3-class labels; will read 0% post-binary)\n",
    "pct_hold = train.groupby(\"Stock\")[\"Signal\"].apply(lambda s: (s == 2).mean())\n",
    "print(\"Tickers with >85% Hold in train (label too tight for them):\")\n",
    "print(pct_hold[pct_hold > 0.85].sort_values(ascending=False).head(20))\n",
    "\n",
    "# After Step B+C the labels are binary {0,1}; check skew per stock instead\n",
    "pct_buy = train.groupby(\"Stock\")[\"Signal\"].apply(lambda s: (s == 1).mean())\n",
    "imbalanced = pct_buy[(pct_buy < 0.15) | (pct_buy > 0.85)]\n",
    "if len(imbalanced):\n",
    "    print(\"\\nTickers with >85% one-class skew in train (K may be wrong for them):\")\n",
    "    print(imbalanced.sort_values().head(20))\n"
   ],
   "outputs": [
    {
