   "source": [
    "def download_and_fix_sp500(cache_path=\"data/SP500.csv\", force_refresh=False):\n",
    "    # Check cache\n",
    "    if not force_refresh and os.path.exists(cache_path):\n",
    "        cached = pd.read_csv(cache_path)\n",
    "        cached_dates = pd.to_datetime(cached.iloc[:, 0], errors='coerce')\n",
    "        last_date = cached_dates.max()\n",
    "        if last_date >= _last_friday() - pd.Timedelta(days=1):\n",
    "            print(f\"Loading SP500 data from cache ({cache_path}), latest date: {last_date.date()}\")\n",
    "            return\n",
    "\n",
    "    y = yf.download(\"^GSPC\", start=\"2015-01-01\", interval=\"1d\")\n",
    "    y = y.resample('W-FRI').agg({\n",
    "          ('Open', \"^GSPC\"): 'first',\n",
    "          ('High', \"^GSPC\"): 'max',\n",
    "          ('Low', \"^GSPC\"): 'min',\n",
    "          ('Close', \"^GSPC\"): 'last',\n",
    "          ('Volume', \"^GSPC\"): 'sum'\n",
    "        })\n",
    "    sp500 = y.copy()\n",
    "\n",
    "    sp500.columns = [\"_\".join(col) if isinstance(col, tuple) else col for col in sp500.columns]\n",
    "\n",
    "    sp500 = sp500.loc[:, ~sp500.columns.isin([\"level_0\", \"index\"])]\n",
    "    sp500.to_csv(cache_path)\n",
    "    print(f\"Downloaded and saved SP500 data to {cache_path}\")"
   ],
   "outputs": [],
   "execution_count": 11
  },
  {
   "cell_type": "code",
   "id": "4f0166c29b0c3b63",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-05-22T02:03:18.039665Z",
     "iopub.status.busy": "2026-05-22T02:03:18.039665Z",
     "iopub.status.idle": "2026-05-22T02:03:18.044685Z",
     "shell.execute_reply": "2026-05-22T02:03:18.043929Z"
    },
    "ExecuteTime": {
