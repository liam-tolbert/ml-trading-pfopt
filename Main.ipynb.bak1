  {
   "cell_type": "code",
   "id": "dfa5f2fd55354fd6",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-05-24T02:35:27.150398800Z",
     "start_time": "2026-05-24T02:35:27.112271900Z"
    }
   },
   "source": [
    "# Diagnostic: why is the 2025 <.30 bucket inverted (actual_buy_rate 0.76)?\n",
    "# Compare feature distributions in the 2025 low-confidence cohort vs the\n",
    "# 2025 high-confidence cohort. If <.30 is dominated by deeply negative idio\n",
    "# momentum (i.e. recent losers that snap back in a bull tape), then the\n",
    "# fix is regime-interacted momentum rather than more raw features.\n",
    "cohort_features = [\n",
    "    \"Idio_Momentum_4wk\", \"Idio_Momentum_12wk\", \"Idio_Momentum_26wk\",\n",
    "    \"Days_Since_Earnings\", \"Post_Earnings_4wk\",\n",
    "    \"Beta_26wk\", \"Returns-1wk-0wklag\", \"Returns-3wk-1wklag\",\n",
    "    \"Bull_Probability\", \"SP500-Returns\",\n",
    "]\n",
    "# Keep only features that exist in the test set\n",
    "cohort_features = [f for f in cohort_features if f in test_df.columns]\n",
    "\n",
    "mask_2025 = test_df[\"year\"] == 2025\n",
    "low_2025  = test_df[mask_2025 & (test_df[\"bucket\"] == \"<.30\")]\n",
    "high_2025 = test_df[mask_2025 & (test_df[\"bucket\"] == \">.70\")]\n",
    "print(f\"2025 <.30 cohort: n={len(low_2025)} | actual_buy_rate={low_2025['y'].mean():.3f}\")\n",
    "print(f\"2025 >.70 cohort: n={len(high_2025)} | actual_buy_rate={high_2025['y'].mean():.3f}\")\n",
    "\n",
    "def summarize(df, feats):\n",
    "    return pd.DataFrame({\n",
    "        \"mean\":   df[feats].mean(),\n",
    "        \"median\": df[feats].median(),\n",
    "        \"p25\":    df[feats].quantile(0.25),\n",
    "        \"p75\":    df[feats].quantile(0.75),\n",
    "    })\n",
    "\n",
    "print(\"\\n--- 2025 <.30 cohort feature distributions ---\")\n",
    "print(summarize(low_2025, cohort_features).round(4))\n",
    "print(\"\\n--- 2025 >.70 cohort feature distributions ---\")\n",
    "print(summarize(high_2025, cohort_features).round(4))\n",
    "\n",
    "# Side-by-side mean comparison + spread\n",
    "side = pd.DataFrame({\n",
    "    \"low_mean\":  low_2025[cohort_features].mean(),\n",
    "    \"high_mean\": high_2025[cohort_features].mean(),\n",
    "})\n",
    "side[\"delta_high_minus_low\"] = side[\"high_mean\"] - side[\"low_mean\"]\n",
    "print(\"\\n--- mean(>.70) vs mean(<.30) for each feature ---\")\n",
    "print(side.round(4).sort_values(\"delta_high_minus_low\"))\n",
    "\n",
    "# Within the 2025 <.30 cohort, split by whether the stock was actually a buy\n",
    "# (y==1) — does the model's miss correlate with any feature?\n",
    "print(\"\\n--- Within 2025 <.30: actual-buy rows vs actual-sell rows ---\")\n",
    "buy_rows  = low_2025[low_2025[\"y\"] == 1]\n",
    "sell_rows = low_2025[low_2025[\"y\"] == 0]\n",
    "inside = pd.DataFrame({\n",
    "    \"actual_buy_mean\":  buy_rows[cohort_features].mean(),\n",
    "    \"actual_sell_mean\": sell_rows[cohort_features].mean(),\n",
    "})\n",
    "inside[\"delta_buy_minus_sell\"] = inside[\"actual_buy_mean\"] - inside[\"actual_sell_mean\"]\n",
    "print(f\"  actual buys n={len(buy_rows)}, actual sells n={len(sell_rows)}\")\n",
    "print(inside.round(4).sort_values(\"delta_buy_minus_sell\"))\n"
   ],
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "2025 <.30 cohort: n=5 | actual_buy_rate=0.000\n",
      "2025 >.70 cohort: n=636 | actual_buy_rate=0.478\n",
      "\n",
      "--- 2025 <.30 cohort feature distributions ---\n",
      "                       mean  median     p25     p75\n",
