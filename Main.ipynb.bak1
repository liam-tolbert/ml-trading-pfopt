   "source": [
    "# ---- Summary line ----\n",
    "from sklearn.metrics import confusion_matrix\n",
    "\n",
    "acc_val  = (y_val  == y_val_pred ).mean()\n",
    "acc_test = (y_test == y_test_pred).mean()\n",
    "print(f\"Accuracy — val: {acc_val:.3f}   test: {acc_test:.3f}\")\n",
    "print(f\"Test class counts: \" + \", \".join(f\"{CLASS_NAMES[c]}={int((y_test==c).sum())}\" for c in class_order))\n",
    "\n",
    "def _print_cm(name, y_true, y_pred):\n",
    "    cm = confusion_matrix(y_true, y_pred, labels=class_order)\n",
    "    header = \"             \" + \"  \".join(f\"pred {CLASS_NAMES[c]:>5s}\" for c in class_order)\n",
    "    print(f\"\\n{name} confusion matrix (rows = true, cols = predicted):\")\n",
    "    print(header)\n",
    "    for i, c in enumerate(class_order):\n",
    "        row = \"  \".join(f\"{cm[i, j]:>10d}\" for j in range(len(class_order)))\n",
    "        print(f\"true {CLASS_NAMES[c]:>5s}  {row}\")\n",
    "    for i, c in enumerate(class_order):\n",
    "        tp = cm[i, i]\n",
    "        fn = cm[i, :].sum() - tp\n",
    "        fp = cm[:, i].sum() - tp\n",
    "        prec = tp / (tp + fp) if (tp + fp) else 0.0\n",
    "        rec  = tp / (tp + fn) if (tp + fn) else 0.0\n",
    "        print(f\"  {CLASS_NAMES[c]:>5s}: precision={prec:.3f}  recall={rec:.3f}\")\n",
    "\n",
    "_print_cm(\"val\",  y_val,  y_val_pred)\n",
    "_print_cm(\"test\", y_test, y_test_pred)"
   ],
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Accuracy — val: 0.457   test: 0.556\n",
