   "cell_type": "code",
   "id": "ca10e2e8-8f7d-4fb1-bf96-f590448c4eae",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-05-22T02:03:14.042969Z",
     "iopub.status.busy": "2026-05-22T02:03:14.042969Z",
     "iopub.status.idle": "2026-05-22T02:03:14.064000Z",
     "shell.execute_reply": "2026-05-22T02:03:14.063242Z"
    },
    "ExecuteTime": {
     "end_time": "2026-05-24T02:29:32.488959600Z",
     "start_time": "2026-05-24T02:29:32.452687300Z"
    }
   },
   "source": [
    "import time\n",
    "import requests as req\n",
    "from tqdm import tqdm\n",
    "\n",
    "EDGAR_HEADERS = {\"User-Agent\": \"MLTradingResearch liam.tolbert02@gmail.com\"}\n",
    "\n",
    "def _build_ticker_to_cik():\n",
    "    \"\"\"Fetch SEC's ticker->CIK mapping and return as a dict.\"\"\"\n",
    "    url = \"https://www.sec.gov/files/company_tickers.json\"\n",
    "    resp = req.get(url, headers=EDGAR_HEADERS)\n",
    "    resp.raise_for_status()\n",
    "    data = resp.json()\n",
    "    return {entry[\"ticker\"].upper(): str(entry[\"cik_str\"]).zfill(10) for entry in data.values()}\n",
    "\n",
    "def _fetch_edgar_facts(cik):\n",
    "    \"\"\"Fetch all XBRL facts for a given 10-digit CIK.\"\"\"\n",
    "    url = f\"https://data.sec.gov/api/xbrl/companyfacts/CIK{cik}.json\"\n",
    "    resp = req.get(url, headers=EDGAR_HEADERS)\n",
    "    resp.raise_for_status()\n",
    "    return resp.json()\n",
    "\n",
    "def _extract_quarterly_series(facts, taxonomy, tag, unit_key=\"USD\"):\n",
    "    \"\"\"\n",
    "    Pull quarterly data points from company-facts JSON.\n",
    "    Returns a DataFrame with columns [Date, val] for 10-Q filings.\n",
    "    \"\"\"\n",
    "    try:\n",
    "        entries = facts[\"facts\"][taxonomy][tag][\"units\"][unit_key]\n",
    "    except KeyError:\n",
    "        return pd.DataFrame()\n",
    "\n",
    "    rows = []\n",
    "    for e in entries:\n",
    "        # Keep quarterly filings (10-Q) and annual (10-K for Q4 approximation)\n",
    "        if e.get(\"form\") in (\"10-Q\", \"10-K\") and e.get(\"fp\") in (\"Q1\", \"Q2\", \"Q3\", \"Q4\", \"FY\"):\n",
    "            rows.append({\n",
    "                \"Date\": pd.to_datetime(e[\"end\"]) if \"end\" in e else pd.to_datetime(e[\"filed\"]),\n",
    "                \"val\": e[\"val\"],\n",
    "                \"form\": e[\"form\"],\n",
    "                \"fp\": e[\"fp\"],\n",
    "                \"fy\": e.get(\"fy\"),\n",
    "                \"filed\": pd.to_datetime(e[\"filed\"]),\n",
    "            })\n",
    "\n",
    "    if not rows:\n",
    "        return pd.DataFrame()\n",
    "\n",
    "    df = pd.DataFrame(rows)\n",
    "    # Deduplicate: keep the latest filing per Date (10-K FY and 10-Q Q4 can share the same end date)\n",
    "    df = df.sort_values(\"filed\").drop_duplicates(subset=[\"Date\"], keep=\"last\")\n",
    "    df = df.set_index(\"Date\").sort_index()\n",
    "    return df[[\"val\"]]\n",
    "\n",
    "# Tag mapping: column name -> (taxonomy, tag, unit)\n",
    "EDGAR_TAGS = {\n",
    "    \"NetIncome\":         (\"us-gaap\", \"NetIncomeLoss\", \"USD\"),\n",
    "    \"Revenue\":           (\"us-gaap\", \"Revenues\", \"USD\"),\n",
    "    \"OperatingIncome\":   (\"us-gaap\", \"OperatingIncomeLoss\", \"USD\"),\n",
    "    \"TotalAssets\":       (\"us-gaap\", \"Assets\", \"USD\"),\n",
    "    \"Equity\":            (\"us-gaap\", \"StockholdersEquity\", \"USD\"),\n",
    "    \"TotalDebt\":         (\"us-gaap\", \"LongTermDebt\", \"USD\"),\n",
    "    \"SharesOutstanding\": (\"us-gaap\", \"CommonStockSharesOutstanding\", \"shares\"),\n",
    "    \"OperatingCashFlow\": (\"us-gaap\", \"NetCashProvidedByUsedInOperatingActivities\", \"USD\"),\n",
    "    \"FreeCashFlow\":      None,  # computed: OperatingCashFlow - CapEx\n",
    "}\n",
    "\n",
    "# Fallback tags for Revenue (some companies use different tags)\n",
    "REVENUE_FALLBACKS = [\n",
    "    (\"us-gaap\", \"RevenueFromContractWithCustomerExcludingAssessedTax\", \"USD\"),\n",
    "    (\"us-gaap\", \"SalesRevenueNet\", \"USD\"),\n",
    "    (\"us-gaap\", \"SalesRevenueGoodsNet\", \"USD\"),\n",
    "]\n",
    "\n",
    "CAPEX_TAG = (\"us-gaap\", \"PaymentsToAcquirePropertyPlantAndEquipment\", \"USD\")\n",
    "\n",
    "def fetch_historical_fundamentals(tickers, delay=0.1, cache_path=\"data/historical_fundamentals.csv\", force_refresh=False):\n",
    "    \"\"\"\n",
    "    Fetch quarterly fundamentals from SEC EDGAR XBRL API (data from ~2009+).\n",
    "    Returns a dict of {ticker: DataFrame} with quarterly dates as index.\n",
    "\n",
    "    Uses cached CSV if it exists and its latest date is within 90 days.\n",
    "    Set force_refresh=True to bypass cache.\n",
    "    \"\"\"\n",
    "    # Check cache\n",
    "    if not force_refresh and os.path.exists(cache_path):\n",
    "        cached = pd.read_csv(cache_path, parse_dates=[\"Date\"])\n",
    "        latest_date = cached[\"Date\"].max()\n",
    "        if (pd.Timestamp.now() - latest_date).days < 90:\n",
    "            print(f\"Loading fundamentals from cache ({cache_path}), latest date: {latest_date.date()}\")\n",
    "            historical_fund = {}\n",
    "            for ticker_str, grp in cached.groupby(\"Stock\"):\n",
    "                historical_fund[ticker_str] = grp.set_index(\"Date\").drop(columns=[\"Stock\"]).sort_index()\n",
    "            return historical_fund\n",
    "\n",
    "    print(\"Building ticker -> CIK mapping...\")\n",
    "    ticker_to_cik = _build_ticker_to_cik()\n",
    "\n",
    "    historical_fund = {}\n",
    "    failed = []\n",
    "\n",
    "    for ticker_str in tqdm(tickers, desc=\"Fetching fundamentals from SEC EDGAR\"):\n",
    "        cik = ticker_to_cik.get(ticker_str.upper())\n",
    "        if cik is None:\n",
    "            failed.append(ticker_str)\n",
    "            continue\n",
    "\n",
    "        try:\n",
    "            facts = _fetch_edgar_facts(cik)\n",
    "        except Exception as e:\n",
    "            print(f\"  Failed for {ticker_str}: {e}\")\n",
    "            failed.append(ticker_str)\n",
    "            time.sleep(delay)\n",
    "            continue\n",
    "\n",
    "        # Extract each metric\n",
    "        series = {}\n",
    "        for col, tag_info in EDGAR_TAGS.items():\n",
    "            if tag_info is None:\n",
    "                continue  # computed later\n",
    "            taxonomy, tag, unit = tag_info\n",
    "            s = _extract_quarterly_series(facts, taxonomy, tag, unit)\n",
    "            if s.empty and col == \"Revenue\":\n",
    "                # Try fallback revenue tags\n",
    "                for fb_tax, fb_tag, fb_unit in REVENUE_FALLBACKS:\n",
    "                    s = _extract_quarterly_series(facts, fb_tax, fb_tag, fb_unit)\n",
    "                    if not s.empty:\n",
    "                        break\n",
    "            if not s.empty:\n",
    "                series[col] = s[\"val\"]\n",
    "\n",
    "        if not series:\n",
    "            failed.append(ticker_str)\n",
    "            time.sleep(delay)\n",
    "            continue\n",
    "\n",
    "        qdf = pd.DataFrame(series)\n",
    "\n",
    "        # Compute FreeCashFlow = OperatingCashFlow - CapEx\n",
    "        capex = _extract_quarterly_series(facts, *CAPEX_TAG)\n",
    "        if not capex.empty and \"OperatingCashFlow\" in qdf.columns:\n",
    "            capex_aligned = capex[\"val\"].reindex(qdf.index)\n",
    "            qdf[\"FreeCashFlow\"] = qdf[\"OperatingCashFlow\"] - capex_aligned.fillna(0)\n",
    "\n",
    "        qdf.index.name = \"Date\"\n",
    "        historical_fund[ticker_str] = qdf.sort_index()\n",
    "\n",
    "        time.sleep(delay)\n",
    "\n",
    "    if failed:\n",
    "        print(f\"\\nFailed tickers ({len(failed)}): {failed}\")\n",
    "\n",
    "    # Save to cache\n",
    "    frames = [df.assign(Stock=ticker) for ticker, df in historical_fund.items()]\n",
    "    if frames:\n",
    "        pd.concat(frames).reset_index().to_csv(cache_path, index=False)\n",
    "        print(f\"Saved fundamentals cache to {cache_path}\")\n",
    "\n",
    "    return historical_fund"
   ],
   "outputs": [],
   "execution_count": 4
  },
  {
   "cell_type": "code",
   "id": "5490cfeae9784629",
   "metadata": {
    "ExecuteTime": {
