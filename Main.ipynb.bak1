  {
   "cell_type": "code",
   "id": "a9a9904cca1e7d46",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-05-22T02:04:34.916355Z",
     "iopub.status.busy": "2026-05-22T02:04:34.915603Z",
     "iopub.status.idle": "2026-05-22T02:04:47.887797Z",
     "shell.execute_reply": "2026-05-22T02:04:47.887042Z"
    },
    "ExecuteTime": {
     "end_time": "2026-05-24T02:35:40.513836100Z",
     "start_time": "2026-05-24T02:35:27.162289Z"
    }
   },
   "source": [
    "BUY_THRESHOLD = 0.55  # informational only; P(Buy) > this is labeled \"Buy\" in recommendations\n",
    "TOP_N = 10            # rank-only: take top N by P_Buy regardless of absolute threshold\n",
    "ALPHA = 0.5           # P(Buy) influence on expected returns in compute_adjusted_mu\n",
    "\n",
    "def run_model(stock_portfolio):\n",
    "    # Part 1: Predictions\n",
    "    real_df = create_stock_features(stock_portfolio, \"data/stocks.csv\",\n",
    "                                       hist_fund_dict=hist_fundamentals,\n",
    "                                       earnings_dates_dict=earnings_filings)\n",
    "    real_df = real_df.sort_values(by=\"Date\")\n",
    "    today_stocks_features = real_df.loc[[real_df.index.max()]]\n",
    "\n",
    "    features = real_df.drop([\"Stock\", \"Returns-future-1wk\", \"Returns-future-2wk\"], axis=1).columns.values\n",
    "    model = overall_model\n",
    "\n",
    "    probs = model.predict_proba(today_stocks_features[features])[:, 1]  # P(Buy)\n",
    "    tickers = today_stocks_features[\"Stock\"].values\n",
    "\n",
    "    recommendations = pd.DataFrame({\n",
    "        \"Stock\": tickers,\n",
    "        \"P_Buy\": probs,\n",
    "        \"Recommendation\": np.where(probs > BUY_THRESHOLD, \"Buy\", \"Sell\"),\n",
    "    })\n",
    "\n",
    "    # Part 2: Markowitz on top-N by P_Buy (rank-only, no absolute threshold gate)\n",
    "    buy_candidates = recommendations.nlargest(TOP_N, \"P_Buy\")\n",
    "    buy_tickers = buy_candidates[\"Stock\"].tolist()\n",
    "    n_above_threshold = int((recommendations[\"Recommendation\"] == \"Buy\").sum())\n",
    "    print(f\"{n_above_threshold} candidates above P(Buy) > {BUY_THRESHOLD}; taking top {len(buy_tickers)} by P_Buy rank (rank-only)\")\n",
    "    if len(buy_tickers) < 2:\n",
    "        print(\"Fewer than 2 candidates - skipping optimizer\")\n",
    "        return recommendations, {}\n",
    "\n",
    "    buy_stocks_history = extract_ticker_dataframe(\"data/stocks.csv\", buy_tickers[0])[\"Close\"]\n",
    "    for t in buy_tickers[1:]:\n",
    "        a = extract_ticker_dataframe(\"data/stocks.csv\", t)[\"Close\"]\n",
    "        buy_stocks_history = pd.concat([buy_stocks_history, a], axis=1, join=\"inner\")\n",
    "    buy_stocks_history.columns = buy_tickers\n",
    "\n",
    "    buy_probs_series = pd.Series(probs, index=tickers).loc[buy_tickers]\n",
    "\n",
    "    def compute_adjusted_mu(buy_probs, baseline_mu, alpha=0.05):\n",
    "        common = baseline_mu.index.intersection(buy_probs.index)\n",
    "        return baseline_mu.loc[common] * (1 + alpha * (buy_probs.loc[common] - 0.5))\n",
    "\n",
    "    baseline_mu = expected_returns.mean_historical_return(buy_stocks_history)\n",
    "    adjusted_mu = compute_adjusted_mu(buy_probs_series, baseline_mu, alpha=ALPHA)\n",
    "    S = risk_models.sample_cov(buy_stocks_history)\n",
    "    common_tickers = adjusted_mu.index.intersection(S.index)\n",
    "    S = S.loc[common_tickers, common_tickers]\n",
    "\n",
    "    ef = EfficientFrontier(adjusted_mu, S)\n",
    "    ef.max_sharpe()\n",
    "    clean_weights = ef.clean_weights()\n",
    "    weights = OrderedDict((k, v) for k, v in clean_weights.items() if v != 0.0)\n",
    "    return recommendations, weights\n",
    "\n",
    "(recommendations, weights) = run_model(real_stock_portfolio_3)\n",
    "print(f\"Buy candidates (P(Buy) > {BUY_THRESHOLD}): {(recommendations.Recommendation == 'Buy').sum()} / {len(recommendations)}\")\n",
    "print(weights)\n"
   ],
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "0 candidates above P(Buy) > 0.55; taking top 10 by P_Buy rank (rank-only)\n",
      "Buy candidates (P(Buy) > 0.55): 0 / 94\n",
      "OrderedDict({'WMT': 0.04363, 'DKNG': 0.07318, 'PEP': 0.02707, 'NEE': 0.19941, 'BAH': 0.42491, 'EPD': 0.2318})\n"
     ]
    }
   ],
   "execution_count": 33
