    }
   },
   "source": [
    "def fetch_earnings_filing_dates(tickers, delay=0.1,\n",
    "                                cache_path=\"data/earnings_filings_submissions.csv\",\n",
    "                                force_refresh=False):\n",
    "    \"\"\"\n",
    "    Fetch 10-Q/10-K filing dates from the SEC EDGAR *submissions* API\n",
    "    (data.sec.gov/submissions/CIK{cik}.json).\n",
    "\n",
    "    Uses the submissions endpoint rather than company-facts XBRL so coverage\n",
    "    is complete regardless of which us-gaap tags a company reports under.\n",
    "    Captures the public filing date (`filed`) and the period-of-report date\n",
    "    (`fp_end`).\n",
    "\n",
    "    Returns dict of {ticker: DataFrame[filed, fp_end]} sorted by filing date.\n",
    "    Cached to CSV; reuses cache if latest filing is <90 days old.\n",
    "\n",
    "    Note: only fetches the `recent` block (latest ~1000 forms per company),\n",
    "    which for a typical large-cap covers ~20 years of filings — sufficient\n",
    "    for our 2009+ training window. If a stock filed extremely frequently\n",
    "    (e.g. hundreds of 8-Ks/year), older 10-Qs may live in the archive\n",
    "    submission files; extend by walking sub[\"filings\"][\"files\"] if needed.\n",
    "    \"\"\"\n",
    "    if not force_refresh and os.path.exists(cache_path):\n",
    "        cached = pd.read_csv(cache_path, parse_dates=[\"filed\", \"fp_end\"])\n",
    "        latest = cached[\"filed\"].max()\n",
    "        if (pd.Timestamp.now() - latest).days < 90:\n",
    "            print(f\"Loading filing dates from cache ({cache_path}), latest filing: {latest.date()}\")\n",
    "            out = {}\n",
    "            for tk, grp in cached.groupby(\"Stock\"):\n",
    "                out[tk] = (grp[[\"filed\", \"fp_end\"]]\n",
    "                           .sort_values(\"filed\")\n",
    "                           .reset_index(drop=True))\n",
    "            return out\n",
    "\n",
    "    print(\"Building ticker -> CIK mapping...\")\n",
    "    ticker_to_cik = _build_ticker_to_cik()\n",
    "\n",
    "    out = {}\n",
    "    for ticker_str in tqdm(tickers, desc=\"Fetching 10-Q/10-K dates (submissions API)\"):\n",
    "        cik = ticker_to_cik.get(ticker_str.upper())\n",
    "        if cik is None:\n",
    "            continue\n",
    "        try:\n",
    "            url = f\"https://data.sec.gov/submissions/CIK{cik}.json\"\n",
    "            resp = req.get(url, headers=EDGAR_HEADERS)\n",
    "            resp.raise_for_status()\n",
    "            sub = resp.json()\n",
    "        except Exception as e:\n",
    "            print(f\"  Failed for {ticker_str}: {e}\")\n",
    "            time.sleep(delay)\n",
    "            continue\n",
    "\n",
    "        recent = sub.get(\"filings\", {}).get(\"recent\", {})\n",
    "        forms = recent.get(\"form\", [])\n",
    "        filing_dates = recent.get(\"filingDate\", [])\n",
    "        report_dates = recent.get(\"reportDate\", [])\n",
    "\n",
    "        rows = []\n",
    "        for f, fd, rd in zip(forms, filing_dates, report_dates):\n",
    "            if f in (\"10-Q\", \"10-K\"):\n",
    "                rows.append({\n",
    "                    \"filed\": pd.to_datetime(fd),\n",
    "                    \"fp_end\": pd.to_datetime(rd) if rd else pd.NaT,\n",
    "                })\n",
    "\n",
    "        if rows:\n",
    "            df = (pd.DataFrame(rows)\n",
    "                  .dropna(subset=[\"filed\"])\n",
    "                  .drop_duplicates(subset=[\"filed\", \"fp_end\"], keep=\"last\")\n",
    "                  .sort_values(\"filed\")\n",
    "                  .reset_index(drop=True))\n",
    "            out[ticker_str] = df\n",
    "\n",
    "        time.sleep(delay)\n",
    "\n",
    "    frames = [df.assign(Stock=tk) for tk, df in out.items()]\n",
    "    if frames:\n",
    "        pd.concat(frames, ignore_index=True).to_csv(cache_path, index=False)\n",
    "        print(f\"Saved filing-dates cache to {cache_path}\")\n",
    "\n",
    "    return out\n"
   ],
   "outputs": [],
   "execution_count": 5
  },
