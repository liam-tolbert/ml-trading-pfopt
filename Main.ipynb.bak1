  {
   "cell_type": "code",
   "id": "548eac63-4026-4551-b895-c9bf5d8afad3",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-05-22T02:04:33.357002Z",
     "iopub.status.busy": "2026-05-22T02:04:33.357002Z",
     "iopub.status.idle": "2026-05-22T02:04:33.361534Z",
     "shell.execute_reply": "2026-05-22T02:04:33.361534Z"
    },
    "ExecuteTime": {
     "end_time": "2026-05-24T02:33:51.573756900Z",
     "start_time": "2026-05-24T02:33:51.564399800Z"
    }
   },
   "source": [
    "K = 0.60  # vol-scaling multiplier; default -- call sites can override via k=\n",
    "\n",
    "def make_signal_column(df, k=None):\n",
    "    \"\"\"\n",
    "    Per-stock vol-scaled binary label.\n",
    "      Buy  (1): Returns-future-1wk >  k * sigma_12wk(Returns-1wk-0wklag)\n",
    "      Sell (0): Returns-future-1wk < -k * sigma_12wk(Returns-1wk-0wklag)\n",
    "      else NaN (dropped - ambiguous)\n",
    "    sigma uses 12 trailing weeks of BACKWARD returns, so no look-ahead.\n",
    "    \"\"\"\n",
    "    k = K if k is None else k\n",
    "    out = df.copy()\n",
    "    out['_sigma'] = (out.groupby('Stock')['Returns-1wk-0wklag']\n",
    "                        .transform(lambda s: s.rolling(12, min_periods=4).std()))\n",
    "    thresh = k * out['_sigma']\n",
    "    out['Signal'] = np.where(out['Returns-future-1wk'] >  thresh, 1,\n",
    "                     np.where(out['Returns-future-1wk'] < -thresh, 0, np.nan))\n",
    "    return out.drop(columns=['_sigma'])\n",
    "\n",
    "\n",
    "def train_val_test_split(df, k=None):\n",
    "    df = make_signal_column(df, k=k)\n",
    "    df = df.dropna(subset=['Returns-future-1wk', 'Returns-future-2wk', 'Signal'])\n",
    "    df['Signal'] = df['Signal'].astype(int)\n",
    "\n",
    "    df = df.sort_values(by='Date')\n",
    "\n",
    "    # 70% train, 15% val, 15% test\n",
    "    split_1 = int(len(df) * 0.7)\n",
    "    split_2 = int(len(df) * 0.85)\n",
    "\n",
    "    train = df.iloc[:split_1]\n",
    "    val = df.iloc[split_1:split_2]\n",
    "    test = df.iloc[split_2:]\n",
    "\n",
    "    return train, val, test\n"
   ],
   "outputs": [],
   "execution_count": 20
  },
  {
   "cell_type": "code",
   "id": "1447ec4f593bf2af",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-05-22T02:04:33.363040Z",
     "iopub.status.busy": "2026-05-22T02:04:33.363040Z",
     "iopub.status.idle": "2026-05-22T02:04:33.368014Z",
     "shell.execute_reply": "2026-05-22T02:04:33.367259Z"
    },
    "ExecuteTime": {
     "end_time": "2026-05-24T02:33:51.587707700Z",
     "start_time": "2026-05-24T02:33:51.575494300Z"
    }
   },
   "source": [
    "def train_model(sets: tuple):\n",
    "    train = sets[0]\n",
    "    features = train.drop([\"Stock\", \"Signal\", \"Returns-future-1wk\", \"Returns-future-2wk\"], axis=1).columns.values\n",
    "    X_train = train[features]\n",
    "    y_train = train[\"Signal\"]\n",
    "\n",
    "    model = XGBClassifier(\n",
    "        objective=\"binary:logistic\",\n",
    "        eval_metric=\"logloss\",\n",
    "        tree_method=\"hist\",\n",
    "        subsample=0.8,\n",
    "        colsample_bytree=0.8,\n",
    "        reg_lambda=2,\n",
    "        reg_alpha=1,\n",
    "        booster=\"gbtree\",\n",
    "        learning_rate=0.05,\n",
    "        gamma=0.5,\n",
    "        min_child_weight=20,\n",
    "        n_estimators=150,\n",
    "        use_label_encoder=False,\n",
    "        random_state=42,\n",
    "        max_depth=4,\n",
    "    )\n",
    "    model.fit(X_train, y_train)\n",
    "\n",
    "    return model\n",
    "\n",
    "def predict(model: XGBClassifier, sets: tuple, val_or_test: str):\n",
    "    val = sets[1]\n",
    "    test = sets[2]\n",
    "    features = val.drop([\"Stock\", \"Signal\", \"Returns-future-1wk\", \"Returns-future-2wk\"], axis=1).columns.values\n",
    "\n",
    "    if val_or_test == \"val\":\n",
    "        x = val[features]\n",
    "        y = val[\"Signal\"]\n",
    "    else:\n",
    "        x = test[features]\n",
    "        y = test[\"Signal\"]\n",
    "\n",
    "    y_pred = model.predict(x)\n",
    "    return classification_report(y, y_pred, output_dict=True)\n"
   ],
   "outputs": [],
   "execution_count": 21
  },
